-transition-new(root){animation:none;mix-blend-mode:normal}.hero-overlay{background:linear-gradient(to right,rgba(7,48,87,0.95),rgba(7,48,87,0.7))}.card-hover-effect:hover{transform:translateY(-8px);box-shadow:0 20px 40px -15px rgba(0,0,0,0.1)}</style></head><body><div class=\"min-h-screen bg-white flex flex-col\"><nav style=\"view-transition-name:main-nav\" class=\"sticky top-0 z-50 border-b border-white/10 bg-[#073057]/95 backdrop-blur supports-[backdrop-filter]:bg-[#073057]/90\"><div class=\"container mx-auto px-6\"><div class=\"flex min-h-[78px] items-center justify-between gap-4\"><a href=\"https://p.superdesign.dev/draft/bd5f15c5-1d98-4427-8a4d-acfc5a2453a1\" id=\"nav-brand-logo\" class=\"flex items-center gap-4 no-underline\"><div class=\"flex h-12 w-12 items-center justify-center rounded-full bg-[#1AAD94] shrink-0 shadow-[0_8px_24px_rgba(26,173,148,0.25)]\"><span class=\"text-base font-bold tracking-widest text-white\">JCL</span></div><div class=\"flex flex-col leading-tight\"><span class=\"text-lg font-extrabold tracking-tighter text-white uppercase\">JOSEOCEANJOBS</span><span class=\"text-[11px] font-medium uppercase tracking-[0.18em] text-white/50\">Jose Consulting Limited</span></div></a><div class=\"hidden xl:flex items-center gap-7\"><a href=\"https://p.superdesign.dev/draft/bd5f15c5-1d98-4427-8a4d-acfc5a2453a1\" id=\"nav-home\" class=\"text-[13px] font-semibold uppercase tracking-[0.08em] text-white/80 transition-colors hover:text-[#1AAD94]\">Home</a><a href=\"https://p.superdesign.dev/draft/dcbb8baf-c311-42eb-8c3b-01359cbbdafc\" id=\"nav-about\" class=\"text-[13px] font-semibold uppercase tracking-[0.08em] text-white/80 transition-colors hover:text-[#1AAD94]\">About</a><a href=\"https://p.superdesign.dev/draft/d2d5d0aa-c669-49b6-9b33-a28441cf4b5d\" id=\"nav-leadership\" class=\"text-[13px] font-bold uppercase tracking-[0.08em] text-[#1AAD94] transition-colors\">Leadership</a><a href=\"https://p.superdesign.dev/draft/254e9f8f-72d8-4ce3-a2b9-61b026d05b1e\" id=\"nav-partnerships\" class=\"text-[13px] font-semibold uppercase tracking-[0.08em] text-white/80 transition-colors hover:text-[#1AAD94]\">Partnerships</a><a href=\"#jobs\" id=\"nav-jobs\" class=\"text-[13px] font-semibold uppercase tracking-[0.08em] text-white/80 transition-colors hover:text-[#1AAD94]\">Jobs</a><a href=\"https://p.superdesign.dev/draft/a44ee394-4e27-4984-95ee-689b5df446b4\" id=\"nav-contact\" class=\"text-[13px] font-semibold uppercase tracking-[0.08em] text-white/80 transition-colors hover:text-[#1AAD94]\">Contact</a></div><div class=\"hidden md:flex items-center gap-3\"><a href=\"#training\" id=\"nav-cta-training\" class=\"inline-flex px-5 py-2.5 border border-white/20 rounded-[8px] text-white text-[12px] font-semibold uppercase tracking-[0.08em] hover:bg-white/10 transition-all\">Request Training</a><a href=\"#pathway\" id=\"nav-cta-register\" class=\"inline-flex px-5 py-2.5 bg-[#1AAD94] rounded-[8px] text-white text-[12px] font-bold uppercase tracking-[0.08em] hover:brightness-110 transition-all\">Start Your Pathway</a></div></div></div></nav><main style=\"view-transition-name:main-content\" class=\"flex-1\"><section class=\"relative h-[480px] flex items-center overflow-hidden bg-[#073057]\"><div class=\"absolute inset-0 z-0\"><img src=\"https://images.unsplash.com/photo-1517048676732-d65bc937f952?auto=format&fit=crop&q=80&w=1600\" alt=\"Leadership Meeting\" class=\"w-full h-full object-cover opacity-60\"><div class=\"absolute inset-0 hero-overlay\"></div></div><div class=\"container mx-auto px-6 relative z-10 text-white\"><div><nav class=\"flex items-center gap-2 mb-8 text-[11px] font-bold uppercase tracking-[0.18em] text-[#1AAD94]\"><a href=\"https://p.superdesign.dev/draft/bd5f15c5-1d98-4427-8a4d-acfc5a2453a1\" class=\"hover:text-white transition-colors\">Home</a><iconify-icon icon=\"lucide:chevron-right\"></iconify-icon><span class=\"text-white/60\">Leadership and Experts</span></nav><h1 class=\"text-5xl md:text-7xl font-extrabold tracking-tight mb-6\">Leadership and Experts</h1><p class=\"text-xl md:text-2xl text-white/70 max-w-2xl leading-relaxed\">The strategic minds and operational veterans driving JCL's vision to architect global maritime talent pathways.</p></div></div></section><section class=\"bg-[#F9FAFB] py-24 md:py-32\"><div class=\"container mx-auto px-6\"><div class=\"grid gap-8 md:grid-cols-2\"><div class=\"rounded-[24px] bg-white p-10 border border-[#E0E0E0] card-hover-effect transition-all duration-300\"><div class=\"flex flex-col md:flex-row md:items-start gap-8 mb-8\"><div class=\"w-20 h-20 shrink-0 rounded-full bg-[#073057] flex items-center justify-center text-white font-bold text-2xl shadow-xl\">JD</div><div class=\"flex-1\"><div class=\"inline-flex px-3 py-1 bg-[#1AAD94]/10 text-[#1AAD94] text-[10px] font-bold uppercase tracking-wider rounded-full mb-3\">Executive</div><h3 class=\"text-3xl font-extrabold text-[#073057] mb-1\">John Doe</h3><p class=\"text-[#1AAD94] text-[12px] font-bold uppercase tracking-widest\">Managing Director</p></div></div><p class=\"text-[#6B7280] leading-relaxed mb-10\">Specializing in global logistics and maritime strategy with over 20 years of operational excellence in offshore energy. John has architected multiple workforce transformation programs for Tier-1 vessel operators across West Africa and Europe.</p><div class=\"flex flex-wrap gap-2 pt-8 border-t border-[#E0E0E0]\"><div class=\"inline-flex items-center gap-1.5 px-3 py-1 bg-gray-100 text-gray-600 rounded-full text-[11px] font-semibold\"><iconify-icon icon=\"lucide:badge-check\" class=\"text-[#1AAD94]\"></iconify-icon><span>Global Logistics</span></div><div class=\"inline-flex items-center gap-1.5 px-3 py-1 bg-gray-100 text-gray-600 rounded-full text-[11px] font-semibold\"><iconify-icon icon=\"lucide:badge-check\" class=\"text-[#1AAD94]\"></iconify-icon><span>Maritime Strategy</span></div><div class=\"inline-flex items-center gap-1.5 px-3 py-1 bg-gray-100 text-gray-600 rounded-full text-[11px] font-semibold\"><iconify-icon icon=\"lucide:badge-check\" class=\"text-[#1AAD94]\"></iconify-icon><span>Offshore Energy</span></div></div></div><div class=\"rounded-[24px] bg-white p-10 border border-[#E0E0E0] card-hover-effect transition-all duration-300\"><div class=\"flex flex-col md:flex-row md:items-start gap-8 mb-8\"><div class=\"w-20 h-20 shrink-0 rounded-full bg-[#073057] flex items-center justify-center text-white font-bold text-2xl shadow-xl\">SA</div><div class=\"flex-1\"><div class=\"inline-flex px-3 py-1 bg-[#1AAD94]/10 text-[#1AAD94] text-[10px] font-bold uppercase tracking-wider rounded-full mb-3\">Training</div><h3 class=\"text-3xl font-extrabold text-[#073057] mb-1\">Sarah Adams</h3><p class=\"text-[#1AAD94] text-[12px] font-bold uppercase tracking-widest\">Head of Training</p></div></div><p class=\"text-[#6B7280] leading-relaxed mb-10\">A certified master trainer overseeing STCW programs and technical workforce development. Sarah ensures all JCL training modules exceed international standards, focusing on high-readiness deployment for offshore specialists.</p><div class=\"flex flex-wrap gap-2 pt-8 border-t border-[#E0E0E0]\"><div class=\"inline-flex items-center gap-1.5 px-3 py-1 bg-gray-100 text-gray-600 rounded-full text-[11px] font-semibold\"><iconify-icon icon=\"lucide:badge-check\" class=\"text-[#1AAD94]\"></iconify-icon><span>STCW Oversight</span></div><div class=\"inline-flex items-center gap-1.5 px-3 py-1 bg-gray-100 text-gray-600 rounded-full text-[11px] font-semibold\"><iconify-icon icon=\"lucide:badge-check\" class=\"text-[#1AAD94]\"></iconify-icon><span>Workforce Dev</span></div><div class=\"inline-flex items-center gap-1.5 px-3 py-1 bg-gray-100 text-gray-600 rounded-full text-[11px] font-semibold\"><iconify-icon icon=\"lucide:badge-check\" class=\"text-[#1AAD94]\"></iconify-icon><span>Intl Standards</span></div></div></div><div class=\"rounded-[24px] bg-white p-10 border border-[#E0E0E0] card-hover-effect transition-all duration-300\"><div class=\"flex flex-col md:flex-row md:items-start gap-8 mb-8\"><div class=\"w-20 h-20 shrink-0 rounded-full bg-[#073057] flex items-center justify-center text-white font-bold text-2xl shadow-xl\">MK</div><div class=\"flex-1\"><div class=\"inline-flex px-3 py-1 bg-[#1AAD94]/10 text-[#1AAD94] text-[10px] font-bold uppercase tracking-wider rounded-full mb-3\">Operations</div><h3 class=\"text-3xl font-extrabold text-[#073057] mb-1\">Marcus Kwesi</h3><p class=\"text-[#1AAD94] text-[12px] font-bold uppercase tracking-widest\">Operations Lead</p></div></div><p class=\"text-[#6B7280] leading-relaxed mb-10\">Expert in vessel mobilization and talent acquisition logistics. Marcus manages the critical pathways connecting trained professionals to specific roles in the West African and European maritime corridors.</p><div class=\"flex flex-wrap gap-2 pt-8 border-t border-[#E0E0E0]\"><div class=\"inline-flex items-center gap-1.5 px-3 py-1 bg-gray-100 text-gray-600 rounded-full text-[11px] font-semibold\"><iconify-icon icon=\"lucide:badge-check\" class=\"text-[#1AAD94]\"></iconify-icon><span>Mobilization</span></div><div class=\"inline-flex items-center gap-1.5 px-3 py-1 bg-gray-100 text-gray-600 rounded-full text-[11px] font-semibold\"><iconify-icon icon=\"lucide:badge-check\" class=\"text-[#1AAD94]\"></iconify-icon><span>Vessel Matching</span></div><div class=\"inline-flex items-center gap-1.5 px-3 py-1 bg-gray-100 text-gray-600 rounded-full text-[11px] font-semibold\"><iconify-icon icon=\"lucide:badge-check\" class=\"text-[#1AAD94]\"></iconify-icon><span>Regional Logistics</span></div></div></div><div class=\"rounded-[24px] bg-white p-10 border border-[#E0E0E0] card-hover-effect transition-all duration-300\"><div class=\"flex flex-col md:flex-row md:items-start gap-8 mb-8\"><div class=\"w-20 h-20 shrink-0 rounded-full bg-[#073057] flex items-center justify-center text-white font-bold text-2xl shadow-xl\">ER</div><div class=\"flex-1\"><div class=\"inline-flex px-3 py-1 bg-[#1AAD94]/10 text-[#1AAD94] text-[10px] font-bold uppercase tracking-wider rounded-full mb-3\">Growth</div><h3 class=\"text-3xl font-extrabold text-[#073057] mb-1\">Elena Rossi</h3><p class=\"text-[#1AAD94] text-[12px] font-bold uppercase tracking-widest\">Strategy & Partnerships</p></div></div><p class=\"text-[#6B7280] leading-relaxed mb-10\">Focused on market expansion and strategic alliances. Elena bridges JCLΓÇÖs capability with global energy firms, ensuring our workforce solutions align with modern ESG and compliance mandates across the industry.</p><div class=\"flex flex-wrap gap-2 pt-8 border-t border-[#E0E0E0]\"><div class=\"inline-flex items-center gap-1.5 px-3 py-1 bg-gray-100 text-gray-600 rounded-full text-[11px] font-semibold\"><iconify-icon icon=\"lucide:badge-check\" class=\"text-[#1AAD94]\"></iconify-icon><span>ESG Compliance</span></div><div class=\"inline-flex items-center gap-1.5 px-3 py-1 bg-gray-100 text-gray-600 rounded-full text-[11px] font-semibold\"><iconify-icon icon=\"lucide:badge-check\" class=\"text-[#1AAD94]\"></iconify-icon><span>Strategic Alliances</span></div><div class=\"inline-flex items-center gap-1.5 px-3 py-1 bg-gray-100 text-gray-600 rounded-full text-[11px] font-semibold\"><iconify-icon icon=\"lucide:badge-check\" class=\"text-[#1AAD94]\"></iconify-icon><span>Expansion</span></div></div></div></div></div></section><section class=\"bg-white py-24 md:py-32\"><div class=\"container mx-auto px-6\"><div class=\"grid gap-8 lg:grid-cols-[1.4fr_0.6fr]\"><div class=\"bg-white rounded-[32px] border border-[#E0E0E0] overflow-hidden p-8 md:p-12 shadow-sm\"><div class=\"inline-flex px-4 py-1.5 bg-[#073057] text-white text-[11px] font-bold uppercase tracking-widest rounded-full mb-8\">What this means for delivery</div><h2 class=\"text-[40px] md:text-[52px] font-extrabold text-[#073057] leading-[1.1] mb-8\">A combined force of industry-shaping capability.</h2><p class=\"text-lg text-[#6B7280] leading-relaxed mb-12 max-w-2xl\">Our leadership team doesn't just consult; they've lived the operations. This ensures that every JCL solutionΓÇöfrom training programs to mobilization logisticsΓÇöis grounded in the realities of the modern maritime environment. We bridge the gap between high-level strategy and tactical execution on the deck.</p><img src=\"https://images.unsplash.com/photo-1521737604893-d14cc237f11d?auto=format&fit=crop&q=80&w=1200\" alt=\"Expert Collaboration\" class=\"w-full h-[400px] object-cover rounded-[24px]\"></div><div class=\"bg-[#073057] rounded-[32px] p-8 md:p-12 text-white flex flex-col justify-center\"><div class=\"inline-flex px-4 py-1.5 border border-white/20 text-[#1AAD94] text-[11px] font-bold uppercase tracking-widest rounded-full mb-10 w-fit\">Explore further</div><h3 class=\"text-3xl font-bold mb-12\">Connect with our specialized team today.</h3><div class=\"space-y-4\"><a href=\"#methodology\" id=\"delivery-btn-method\" class=\"flex items-center justify-between w-full px-8 py-5 bg-white/5 border border-white/10 rounded-2xl hover:bg-white/10 transition-all group font-bold\"><span class=\"text-[15px]\">Our Methodology</span><iconify-icon icon=\"lucide:arrow-right\" class=\"group-hover:translate-x-2 transition-transform\"></iconify-icon></a><a href=\"#case-studies\" id=\"delivery-btn-cases\" class=\"flex items-center justify-between w-full px-8 py-5 bg-white/5 border border-white/10 rounded-2xl hover:bg-white/10 transition-all group font-bold\"><span class=\"text-[15px]\">Case Studies</span><iconify-icon icon=\"lucide:arrow-right\" class=\"group-hover:translate-x-2 transition-transform\"></iconify-icon></a><a href=\"https://p.superdesign.dev/draft/a44ee394-4e27-4984-95ee-689b5df446b4\" id=\"delivery-btn-contact\" class=\"flex items-center justify-between w-full px-8 py-5 bg-[#1AAD94] rounded-2xl hover:brightness-110 transition-all group font-bold\"><span class=\"text-[15px]\">Contact an Expert</span><iconify-icon icon=\"lucide:message-square\" class=\"group-hover:scale-110 transition-transform\"></iconify-icon></a></div></div></div></div></section></main><footer style=\"view-transition-name:footer\" class=\"bg-[#073057] text-white pt-24 pb-12\"><div class=\"container mx-auto px-6\"><div class=\"grid gap-14 lg:grid-cols-12 mb-18 pb-16\"><div class=\"lg:col-span-4\"><div class=\"flex items-center gap-4 mb-8\"><div class=\"flex h-12 w-12 items-center justify-center rounded-full bg-[#1AAD94] shadow-[0_8px_24px_rgba(26,173,148,0.25)]\"><span class=\"text-base font-bold tracking-widest text-white\">JCL</span></div><div class=\"flex flex-col leading-tight\"><span class=\"text-lg font-extrabold tracking-tighter uppercase text-white\">JOSEOCEANJOBS</span><span class=\"text-[11px] font-medium uppercase tracking-[0.18em] text-white/45\">Jose Consulting Limited</span></div></div><p class=\"max-w-md text-[15px] leading-relaxed text-white/65 mb-8\">Jose Consulting Limited helps individuals and organizations strengthen employability, workforce readiness, and global opportunity pathways across the maritime and energy sectors.</p><div class=\"grid sm:grid-cols-2 gap-4 text-sm text-white/55\"><div class=\"rounded-[14px] border border-white/10 bg-white/5 p-4\"><div class=\"text-[#1AAD94] font-bold uppercase tracking-[0.16em] text-[10px] mb-2\">Sector focus</div><p>Maritime and energy workforce development</p></div><div class=\"rounded-[14px] border border-white/10 bg-white/5 p-4\"><div class=\"text-[#1AAD94] font-bold uppercase tracking-[0.16em] text-[10px] mb-2\">Mobilization</div><p>Specialist teams deploy within two weeksΓÇÖ notice</p></div></div></div><div class=\"lg:col-span-2\"><h4 class=\"mb-6 text-[13px] font-bold uppercase tracking-[0.18em] text-[#1AAD94]\">Explore</h4><ul class=\"space-y-3 text-white/65\"><li><a href=\"https://p.superdesign.dev/draft/dcbb8baf-c311-42eb-8c3b-01359cbbdafc\" id=\"footer-about\" class=\"hover:text-white transition-colors\">About JCL</a></li><li><a href=\"https://p.superdesign.dev/draft/d2d5d0aa-c669-49b6-9b33-a28441cf4b5d\" id=\"footer-leadership\" class=\"hover:text-white transition-colors\">Leadership & Experts</a></li><li><a href=\"https://p.superdesign.dev/draft/254e9f8f-72d8-4ce3-a2b9-61b026d05b1e\" id=\"footer-partners\" class=\"hover:text-white transition-colors\">Partnerships & Expertise</a></li><li><a href=\"https://p.superdesign.dev/draft/a44ee394-4e27-4984-95ee-689b5df446b4\" id=\"footer-contact\" class=\"hover:text-white transition-colors\">Contact JCL</a></li></ul></div><div class=\"lg:col-span-2\"><h4 class=\"mb-6 text-[13px] font-bold uppercase tracking-[0.18em] text-[#1AAD94]\">Platform</h4><ul class=\"space-y-3 text-white/65\"><li><a href=\"#jobs\" id=\"footer-jobs\" class=\"hover:text-white transition-colors\">Browse Jobs</a></li><li><a href=\"#news\" id=\"footer-news\" class=\"hover:text-white transition-colors\">News & Insights</a></li><li><a href=\"#directory\" id=\"footer-directory\" class=\"hover:text-white transition-colors\">Industry Directory</a></li><li><a href=\"#register\" id=\"footer-register\" class=\"hover:text-white transition-colors\">Start Your Pathway</a></li></ul></div><div class=\"lg:col-span-4\"><h4 class=\"mb-6 text-[13px] font-bold uppercase tracking-[0.18em] text-[#1AAD94]\">How we help</h4><div class=\"space-y-4\"><div class=\"rounded-[14px] border border-white/10 bg-white/5 p-5\"><h5 class=\"font-bold text-white mb-1\">Training & consulting enquiries</h5><p class=\"text-sm leading-relaxed text-white/60\">Use the contact flow to discuss workforce development programs, technical training, or operational consulting support.</p></div><div class=\"rounded-[14px] border border-white/10 bg-white/5 p-5\"><h5 class=\"font-bold text-white mb-1\">Talent pathways</h5><p class=\"text-sm leading-relaxed text-white/60\">Candidates can register, browse opportunities, and connect their skills to future-ready roles.</p></div></div></div></div><div class=\"pt-10 border-t border-white/10 flex flex-col gap-4 md:flex-row md:items-center md:justify-between\"><p class=\"text-[12px] font-medium tracking-[0.1em] uppercase text-white/25\">┬⌐ 2024 Jose Consulting Limited. All rights reserved.</p><div class=\"flex flex-wrap items-center gap-6 text-white/30 text-[11px] font-bold uppercase tracking-[0.12em]\"><div class=\"flex items-center gap-2\"><iconify-icon icon=\"lucide:globe\" class=\"text-lg\"></iconify-icon><span>Global collaboration</span></div><div class=\"flex items-center gap-2\"><iconify-icon icon=\"lucide:badge-check\" class=\"text-lg\"></iconify-icon><span>Industry-ready capability</span></div><div class=\"flex items-center gap-2\"><iconify-icon icon=\"lucide:briefcase-business\" class=\"text-lg\"></iconify-icon><span>Career pathways</span></div></div></div></div></footer></div></body></html>"
