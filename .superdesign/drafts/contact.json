ade-in}@keyframes fade-out{from{opacity:1}to{opacity:0}}@keyframes fade-in{from{opacity:0}to{opacity:1}}::view-transition-old(root),::view-transition-new(root){animation:none;mix-blend-mode:normal}</style></head><body><div class=\"min-h-screen bg-white flex flex-col\"><nav class=\"sticky top-0 z-50 border-b border-white/10 bg-[#073057]\" style=\"view-transition-name: main-nav\"><div class=\"container mx-auto px-6\"><div class=\"flex min-h-[78px] items-center justify-between gap-4\"><a href=\"https://p.superdesign.dev/draft/bd5f15c5-1d98-4427-8a4d-acfc5a2453a1\" id=\"nav-brand-logo\" class=\"flex items-center gap-4 no-underline\" style=\"view-transition-name: brand\"><div class=\"flex h-12 w-12 items-center justify-center rounded-full bg-[#1AAD94] shrink-0 shadow-[0_8px_24px_rgba(26,173,148,0.25)]\"><span class=\"text-base font-bold tracking-widest text-white\">JCL</span></div><div class=\"flex flex-col leading-tight\"><span class=\"text-lg font-extrabold tracking-tighter text-white uppercase\">JOSEOCEANJOBS</span><span class=\"text-[11px] font-medium uppercase tracking-[0.18em] text-white/50\">Jose Consulting Limited</span></div></a><div class=\"hidden xl:flex items-center gap-7\"><a href=\"https://p.superdesign.dev/draft/bd5f15c5-1d98-4427-8a4d-acfc5a2453a1\" id=\"nav-home\" class=\"text-[13px] font-semibold uppercase tracking-[0.08em] text-white/80 transition-colors hover:text-[#1AAD94]\">Home</a><a href=\"https://p.superdesign.dev/draft/dcbb8baf-c311-42eb-8c3b-01359cbbdafc\" id=\"nav-about\" class=\"text-[13px] font-semibold uppercase tracking-[0.08em] text-white/80 transition-colors hover:text-[#1AAD94]\">About</a><a href=\"https://p.superdesign.dev/draft/d2d5d0aa-c669-49b6-9b33-a28441cf4b5d\" id=\"nav-leadership\" class=\"text-[13px] font-semibold uppercase tracking-[0.08em] text-white/80 transition-colors hover:text-[#1AAD94]\">Leadership</a><a href=\"https://p.superdesign.dev/draft/254e9f8f-72d8-4ce3-a2b9-61b026d05b1e\" id=\"nav-partnerships\" class=\"text-[1